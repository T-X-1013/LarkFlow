# Per-demand product directory — regenerated from LarkFlow/templates/kratos-skeleton each run
demo-app/

# Kratos / Go generated artifacts (regenerated by `make api` / `make wire`)
# These patterns are SCOPED under demo-app/ and templates/; we never commit generated files.
# templates/kratos-skeleton/ intentionally has NO generated code — build it via `make api && make wire`.
demo-app/**/wire_gen.go
demo-app/**/*.pb.go
demo-app/**/*_grpc.pb.go
demo-app/**/*_http.pb.go
demo-app/**/*_errors.pb.go
LarkFlow/templates/kratos-skeleton/**/wire_gen.go
LarkFlow/templates/kratos-skeleton/**/*.pb.go
LarkFlow/templates/kratos-skeleton/**/*_grpc.pb.go
LarkFlow/templates/kratos-skeleton/**/*_http.pb.go
LarkFlow/templates/kratos-skeleton/**/*_errors.pb.go
*.db
*.db-journal

# LarkFlow 会话持久化 (A1, pipeline/persistence.py 默认写入 .larkflow/sessions.db)
.larkflow/

# pytest-cov 本地覆盖率数据
.coverage
htmlcov/
coverage.xml
