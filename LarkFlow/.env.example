LLM_PROVIDER=anthropic
# 可选值: anthropic / openai / qwen / doubao

# Database
DATABASE_URL=sqlite:///demo-app/app.db
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/larkflow_demo
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/larkflow_demo

# 飞书应用机器人 (Bot API)
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
LARK_CHAT_ID=ou_xxx
LARK_RECEIVE_ID_TYPE=open_id

# 多维表格记录事件 + 审批卡片（需 scope: docs:event:subscribe / bitable:app / bitable:app:readonly）
# Base 的 obj_token（知识库里的 Base 需用 wiki.get_node 先换算）
LARK_DEMAND_BASE_TOKEN=
# 需求表的 table_id（URL 里 ?table=tblxxx）
LARK_DEMAND_TABLE_ID=
# 启动卡片 / 技术方案文档授权的接收方；target 可以是群 chat_id，也可以是某个人的 open_id
LARK_DEMAND_APPROVE_TARGET=
# receive_id_type: chat_id（发群）或 open_id（发私聊），默认 open_id
LARK_DEMAND_APPROVE_RECEIVE_ID_TYPE=open_id
# 以下字段名有默认值，只有 Base 里用了别的列名时才覆盖，有了别名，要更新对应的字段名
# LARK_DEMAND_STATUS_FIELD=状态
# LARK_DEMAND_ID_FIELD=需求ID
# LARK_DEMAND_DOC_FIELD=需求文档

# 技术方案文档（Phase 1 审批卡用）
LARK_TECH_DOC_FIELD=技术方案文档
# 可选：指定新建 docx 归属的文件夹；未配置时落在 bot 根目录；如果配置了，要让机器人对文件夹有编辑权；且开通docx:document，drive:drive
LARK_TECH_DOC_FOLDER_TOKEN=
# 可选：自建飞书时覆盖文档域名，默认 https://feishu.cn
# LARK_DOC_DOMAIN=https://feishu.cn

# OpenTelemetry
# 宿主机直连本地 collector 时通常用 localhost:4317；容器内运行时改为 otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=larkflow

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Codex / OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-codex
OPENAI_REASONING_EFFORT=medium

# Qwen / DashScope
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus
# 也兼容 DashScope 命名:
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus

# Doubao / Ark
DOUBAO_API_KEY=ark-...
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-...
# 也兼容 Ark 命名:
# ARK_API_KEY=ark-...
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=ep-...
# ARK_ENDPOINT_ID=ep-...
DOUBAO_MAX_RETRIES=3
DOUBAO_RETRY_BASE_SECONDS=5
DOUBAO_RETRY_MAX_SECONDS=60
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BASE_SECONDS=5
OPENAI_RETRY_MAX_SECONDS=60

# Deploy / Image Mirrors
# LARKFLOW_GO_IMAGE=registry.example.com/library/golang:1.22-alpine
# LARKFLOW_ALPINE_MIRROR=https://mirrors.example.com/alpine
# LARKFLOW_GO_PROXY=https://goproxy.cn,https://proxy.golang.org,direct
# LARKFLOW_PYTHON_IMAGE=registry.example.com/library/python:3.11-slim
# LARKFLOW_DEBIAN_MIRROR=https://mirrors.example.com/debian
# LARKFLOW_DEBIAN_SECURITY_MIRROR=https://mirrors.example.com/debian-security

# ==========================================
# Phase 0：规范化 + 澄清回路
# 完整测试：开启 LLM 分类器；低置信度/blocking 会挂起澄清
# ==========================================
LARKFLOW_PHASE0_LLM_ENABLED=1
LARKFLOW_PHASE0_CONFIDENCE_FLOOR=0.75
LARKFLOW_PHASE0_MODEL=gpt-4o-mini
# 复用上面的 OPENAI_API_KEY / OPENAI_BASE_URL；如需独立 provider 取消下面注释
# LARKFLOW_PHASE0_API_KEY=
# LARKFLOW_PHASE0_BASE_URL=

# ==========================================
# Skill Router 语义召回（Tier-2 embedding 同义词兜底）
# ==========================================
LARKFLOW_SEMANTIC_ROUTER_ENABLED=1
LARKFLOW_SEMANTIC_ROUTER_THRESHOLD=0.45
LARKFLOW_EMBEDDING_MODEL=text-embedding-3-small
# LARKFLOW_EMBEDDING_API_KEY=
# LARKFLOW_EMBEDDING_BASE_URL=

# ==========================================
# Skill 闸门（Phase 2 结束前强制读齐 baseline/conditional skill）
# ==========================================
LARKFLOW_SKILL_GATE_ENABLED=1
LARKFLOW_SKILL_GATE_MAX_RETRIES=2